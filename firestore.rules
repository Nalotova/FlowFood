rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0. Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isMember(householdId) {
      return isSignedIn() && (
        request.auth.uid == get(/databases/$(database)/documents/households/$(householdId)).data.ownerUserId ||
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.get('memberUserIds', [])
      );
    }

    // 1. User Profiles (Private)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // 2. Households
    match /households/{householdId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.ownerUserId ||
        request.auth.uid in resource.data.get('memberUserIds', [])
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.ownerUserId ||
        request.auth.uid in resource.data.get('memberUserIds', []) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberUserIds', 'lastAcceptedInviteId', 'updatedAt']) &&
          request.auth.uid in request.resource.data.memberUserIds &&
          !(request.auth.uid in resource.data.get('memberUserIds', [])) &&
          'lastAcceptedInviteId' in request.resource.data &&
          getAfter(/databases/$(database)/documents/householdInvites/$(request.resource.data.lastAcceptedInviteId)).data.householdId == householdId &&
          getAfter(/databases/$(database)/documents/householdInvites/$(request.resource.data.lastAcceptedInviteId)).data.invitedEmail == request.auth.token.email.lower() &&
          getAfter(/databases/$(database)/documents/householdInvites/$(request.resource.data.lastAcceptedInviteId)).data.status == 'accepted'
        )
      );

      // Profiles subcollection
      match /profiles/{profileId} {
        allow read, write: if isMember(householdId);
      }
      
      // Fridge Items subcollection
      match /fridgeItems/{itemId} {
        allow read, write: if isMember(householdId);
      }
      
      // Food Log entries
      match /foodLogEntries/{entryId} {
        allow read, write: if isMember(householdId);
      }
      
      // Cooking History
      match /cookingHistory/{resultId} {
        allow read, write: if isMember(householdId);
      }
    }

    // 3. Invites
    match /householdInvites/{inviteId} {
      allow read: if isSignedIn() && (
        request.auth.token.email.lower() == resource.data.invitedEmail ||
        request.auth.uid == resource.data.invitedByUserId ||
        isMember(resource.data.householdId)
      );
      allow create: if isSignedIn() && isMember(request.resource.data.householdId);
      allow update: if isSignedIn() && (
        request.auth.token.email.lower() == resource.data.invitedEmail ||
        request.auth.uid == resource.data.invitedByUserId ||
        isMember(resource.data.householdId)
      );
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.invitedByUserId ||
        request.auth.uid == get(/databases/$(database)/documents/households/$(resource.data.householdId)).data.ownerUserId
      );
    }
  }
}
